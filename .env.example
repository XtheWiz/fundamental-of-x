# Cloudflare Web Analytics token (optional).
# Sign up free at one.dash.cloudflare.com → Web Analytics → Add a site.
# Without this, no analytics script loads.
#
# Copy this file to .env.production and fill in the token, then `npm run publish`.
# The token is not a secret — it appears in the beacon script tag anyway.

VITE_CF_ANALYTICS_TOKEN=
